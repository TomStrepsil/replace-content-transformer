{
  "name": "replace-content-transformer",
  "version": "1.2.0",
  "description": "A low-dependency WHATWG Transformer / Node Transform that rewrites whilst streaming, respecting chunk boundaries",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": ">=24"
    },
    "packageManager": {
      "name": "npm"
    }
  },
  "keywords": [
    "stream",
    "streaming",
    "transformer",
    "replacement"
  ],
  "license": "ISC",
  "author": {
    "name": "Tom Pereira",
    "url": "https://github.com/TomStrepsil"
  },
  "bugs": {
    "url": "https://github.com/TomStrepsil/replace-content-transformer/issues"
  },
  "homepage": "https://github.com/TomStrepsil/replace-content-transformer#readme",
  "type": "module",
  "main": "./lib/index.cjs",
  "module": "./lib/index.js",
  "types": "./lib/index.d.ts",
  "typesVersions": {
    "*": {
      "web": [
        "lib/adapters/web/index.d.ts"
      ],
      "node": [
        "lib/adapters/node/index.d.ts"
      ]
    }
  },
  "exports": {
    "./web": {
      "types": {
        "import": "./lib/adapters/web/index.d.ts",
        "require": "./lib/adapters/web/index.d.cts"
      },
      "deno": "./lib/adapters/web/index.js",
      "bun": "./lib/adapters/web/index.js",
      "browser": "./lib/adapters/web/index.js",
      "require": "./lib/adapters/web/index.cjs",
      "import": "./lib/adapters/web/index.js",
      "default": "./lib/adapters/web/index.js"
    },
    "./node": {
      "types": {
        "import": "./lib/adapters/node/index.d.ts",
        "require": "./lib/adapters/node/index.d.cts"
      },
      "require": "./lib/adapters/node/index.cjs",
      "import": "./lib/adapters/node/index.js",
      "default": "./lib/adapters/node/index.js"
    },
    ".": {
      "types": {
        "import": "./lib/index.d.ts",
        "require": "./lib/index.d.cts"
      },
      "require": "./lib/index.cjs",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TomStrepsil/replace-content-transformer.git"
  },
  "workspaces": [
    "test/benchmarks"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prepublishOnly": "npm run build",
    "build": "node build.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:watch": "vitest",
    "check:attw": "npm run build && attw --pack .",
    "bench": "npm run bench:node -w test/benchmarks",
    "bench:runtimes": "npm run bench:runtimes -w test/benchmarks",
    "bench:algorithms": "npm run bench:algorithms -w test/benchmarks",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix"
    ]
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "dependencies": {
    "regex-partial-match": "^0.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.11",
    "@types/deno": "^2.5.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-plugin-vitest-globals": "^1.6.1",
    "globals": "^17.4.0",
    "lint-staged": "^16.4.0",
    "msw": "^2.12.14",
    "rimraf": "^6.1.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2",
    "@arethetypeswrong/cli": "^0.18.2"
  }
}
